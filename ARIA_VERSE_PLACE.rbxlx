<?xml version="1.0" encoding="UTF-8"?>
<!--
 Aria Verse Place File
 Description: Roblox game place file for Aria Verse game containing SatoshiVault, PhobosEvent, and ViralHub systems
 Last Modified: 2026-05-01
 Creator: aria-agentworks
 Version: 1.0
-->
<root xmlns="http://roblox.com" xmlns:r="http://roblox.com">
  <!-- Aria Verse Place -->
  <text name="ARIA_VERSE_PLACE"/>

  <!-- Workspace Structure -->
  <folder name="Workspace">
    <folder name="AriaVerseAssets">
      <folder name="PhobosEventEffects" description="Folder for debris, crater, hazard placeholders"/>
    </folder>
  </folder>

  <!-- Lighting Properties -->
  <artificialLight name="Lighting">
    <property name="AtmosphericQuality" value="Custom"/>
    <property name="FogEnd" value="100"/>
    <property name="Ambient" value="Color3.fromRGB(30, 20, 40)"/>
    <property name="OutdoorAmbient" value="Color3.fromRGB(50, 40, 70)"/>
    <light type="SunRiseLight" name="SunRiseLight" intensity="1.5"/>
    <environmentBlendMode value="Opaque"/>
    <technology value="Progressive"/>
  </artificialLight>

  <!-- Sound Structure -->
  <folder name="AriaVerseSounds">
    <sound name="EventMusic" description="Placeholder for Phobos Event music" loops="true" volume="0.5" playOnRecord="false">
      <property name="SoundId" value="rbxassetid://0"/>
      <property name="Volume" value="0.5"/>
      <property name="TimePosition" value="0"/>
    </sound>
    <sound name="VaultChime" description="Placeholder for Satoshi Vault sounds" loops="false" volume="1.0" playOnRecord="false">
      <property name="SoundId" value="rbxassetid://0"/>
      <property name="Volume" value="1.0"/>
      <property name="TimePosition" value="0"/>
    </sound>
  </folder>

  <!-- ScreenGui for UI elements -->
  <screenGui name="AriaVerseUI" resetOnSpawn="false" zIndexBehaviour="S ortBelow">
    <textLabel name="ThemeLabel" text="AriaVerse" font="Gotham" fontSize="AbsoluteMedium">
      <property name="TextColor3" value="Color3.fromRGB(150, 120, 200)"/>
      <property name="BackgroundColor3" value="Color3.fromRGB(30, 20, 40)"/>
    </textLabel>
  </screenGui>

  <!-- ReplicatedStorage Structure -->
  <folder name="ReplicatedStorage">
    <folder name="AriaVerseData">
      <remoteEvent name="SatoshiVaultRemote" description="RemoteEvent for Satoshi Vault interactions"/>
      <remoteEvent name="PhobosEventRemote" description="RemoteEvent for Phobos Event system"/>
      <remoteEvent name="AnalyticsRemote" description="RemoteEvent for analytics tracking"/>
      
      <folder name="Scripts">
        <!-- Client script linking to lua/aria-verse/viral_hub_client.lua -->
        <script name="ViralHubClient" sourceLinked="true" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/viral_hub_client.lua" readOnly="true"/>
      </folder>
    </folder>

    <!-- Additional modules for AriaVerse -->
    <moduleScript name="AriaVerseConfig" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/init.lua" sourceLinked="true" readOnly="true">
      <property name="AriaVerseTheme" value="default"/>
      <property name="Version" value="1.0"/>
    </moduleScript>
  </folder>

  <!-- ServerScriptService Structure -->
  <folder name="ServerScriptService">
    <folder name="AriaVerse">
      <!-- SatoshiVault Server Script -->
      <folder name="SatoshiVault" description="Satoshi Vault system folder">
        <script name="satoshi_vault_server" sourceLinked="true" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/satoshi_vault_server.lua">
          <property name="Enabled" value="true"/>
        </script>
      </folder>

      <!-- PhobosEvent Server Script -->
      <folder name="PhobosEvent" description="Phobos Event system folder">
        <script name="phobos_event_server" sourceLinked="true" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/phobos_event_server.lua">
          <property name="Enabled" value="true"/>
        </script>
      </folder>

      <!-- ViralHub Agent Script -->
      <folder name="ViralHub" description="ViralHub agent system folder">
        <script name="viral_hub_agent" sourceLinked="true" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/viral_hub_agent.lua">
          <property name="Enabled" value="true"/>
        </script>
      </folder>

      <!-- Main Initialization ModuleScript -->
      <moduleScript name="init" description="Main initialization script for AriaVerse">
        <property name="source" value="-- AriaVerse Main Initialization
-- Version: 1.0
-- Creator: aria-agentworks

local AriaVerse = {}
AriaVerse.Version = &quot;1.0&quot;
AriaVerse.Theme = {
    Primary = Color3.fromRGB(150, 120, 200),
    Secondary = Color3.fromRGB(30, 20, 40),
    Accent = Color3.fromRGB(50, 40, 70)
}

-- Initialize subsystems
function AriaVerse:Initialize()
    print(&quot;AriaVerse initializing...&quot;)
    -- Subsystem initialization will occur here
end

return AriaVerse"/>
      </moduleScript>
    </folder>

    <!-- AriaVerse Data Management -->
    <script name="AriaVerseDataManager" sourceLinked="true" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/init.lua">
      <property name="Enabled" value="true"/>
    </script>
  </folder>

  <!-- ServerStorage for server-side data -->
  <folder name="ServerStorage">
    <folder name="AriaVerseAssets" description="Server-side assets for AriaVerse">
      <folder name="SatoshiVault" description="Satoshi Vault server assets"/>
      <folder name="PhobosEvent" description="Phobos Event server assets"/>
      <folder name="ViralHub" description="ViralHub server assets"/>
    </folder>
  </folder>

  <!-- StarterContent -->
  <folder name="StarterContent">
    <folder name="AriaVerse" description="AriaVerse starter content">
      <folder name="Scripts" description="Client scripts for AriaVerse"/>
      <folder name="Modules" description="Client modules for AriaVerse"/>
    </folder>
  </folder>

  <!-- StarterPlayer -->
  <folder name="StarterPlayer">
    <folder name="StarterPlayerScripts">
      <folder name="AriaVerse" description="AriaVerse client scripts">
        <!-- Client-side scripts will be linked here -->
        <script name="ViralHubClientHandler" sourceLinked="true" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/viral_hub_client.lua" readOnly="true">
          <property name="Enabled" value="true"/>
        </script>
      </folder>
    </folder>
    <folder name="StarterPlayerScripts">
      <folder name="AriaVerse" description="AriaVerse client scripts">
        <!-- Client-side scripts will be linked here -->
        <script name="ViralHubClientHandler" sourceLinked="true" sourceUrl="https://github.com/aria-agentworks/-agentworks-bridge/raw/main/lua/aria-verse/viral_hub_client.lua" readOnly="true">
          <property name="Enabled" value="true"/>
        </script>
      </folder>
    </folder>
  </folder>

  <!-- StarterGui for UI elements -->
  <folder name="StarterGui">
    <screenGui name="AriaVerseHUD" resetOnSpawn="false" zIndexBehaviour="SortBelow">
      <frame name="AriaVerseFrame" active="false" size="UDim2.new(1, 0, 1, 0)" visible="true">
        <uiScaleType value="Pixels"/>
        <uiStroke name="BorderStroke" color="Color3.fromRGB(150, 120, 200)" thickness="2" alpha="0.5"/>
        <uiListLayout name="UIListLayout" padding="5" verticalAlignment="Bottom"/>
      </frame>
    </screenGui>
  </folder>

  <!-- TextService Configuration -->
  <textService name="AriaVerseTextConfig" defaultFont="Gotham">
    <property name="ThemeColors" value="{Primary: Color3.fromRGB(150, 120, 200), Secondary: Color3.fromRGB(30, 20, 40)}"/>
    <property name="TextScale" value="1"/>
  </textService>

  <!-- PluginService for AriaVerse tools -->
  <pluginService name="AriaVersePlugins" description="Plugin service for AriaVerse editor tools"/>

  <!-- CollectionService for AriaVerse tags -->
  <collectionService name="AriaVerseTags" description="Collection service for AriaVerse object tagging"/>

  <!-- RunService hooks -->
  <runService name="AriaVerseRunHooks" description="RunService hooks for AriaVerse systems">
    <property name="HeartbeatEnabled" value="true"/>
    <property name="RenderSteppedEnabled" value="true"/>
  </runService>

  <!-- ContextActionService for AriaVerse controls -->
  <contextActionService name="AriaVerseControls" description="Context action service for AriaVerse keyboard controls">
    <property name="MaxActionNameLength" value="64"/>
  </contextActionService>

</root>
