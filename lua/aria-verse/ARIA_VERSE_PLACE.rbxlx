      </Item>
      
      <!-- Lighting Properties -->
      <Item name="Lighting" Class="Lighting">
        <Item name="AtmosphericQuality" value="Custom"/>
        <Item name="FogEnd" type="NumberValue" value="100"/>
        <Item name="Ambient" type="Color3Value" value="Color3.fromRGB(30, 20, 40)"/>
        <Item name="OutdoorAmbient" type="Color3Value" value="Color3.fromRGB(50, 40, 70)"/>
      </Item>
      
      <!-- StarterGui with AriaVerseHUD -->
      <Item name="StarterGui" Class="StarterGui">
        <Item name="AriaVerseHUD" Class="ScreenGui"/>
      </Item>
      
      <!-- StarterPlayer scripts -->
      <Item name="StarterPlayer" Class="StarterPlayer">
        <Item name="ViralHubUI" Class="LocalScript">
          <Item name="Source" value="-- Client UI for viral hub rewards
local player = game.Players.LocalPlayer
local repStorage = game.ReplicatedStorage

print(&quot;[ViralHub UI] Client initialized&quot;)
&quot;/>
        </Item>
      </Item>
    </Items>
  </Game>
</roblox>