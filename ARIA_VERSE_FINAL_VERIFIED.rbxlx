<?xml version="1.0" encoding="UTF-8"?>
<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
  <Settings>
    <Name value="AriaVerse"/>
    <AssetActionOption name="EnabledAssetUpload" value="True"/>
    <ContentFilterSettings FiltersEnabled="false"/>
    <DataModelInfo name="AriaVerse"/>
  </Settings>
  <Game>
    <Instances>
      <Item name="ReplicatedStorage" Class="ReplicatedStorage">
        <Item name="AriaVerseData" Class="Folder">
          <Item name="SatoshiVaultRemote" Class="RemoteEvent"/>
          <Item name="PhobosEventRemote" Class="RemoteEvent"/>
          <Item name="AnalyticsRemote" Class="RemoteEvent"/>
        </Item>
      </Item>
      <Item name="ServerScriptService" Class="ServerScriptService">
        <Item name="AriaVerse" Class="Folder">
          <Item name="init.lua" Class="ModuleScript">
            <Item name="Name" value="init.lua"/>
            <Item name="Source">
<![CDATA[
print("AriaVerse Initializing...")
local SatoshiVault = require(script:FindFirstChild("satoshi_vault_server.lua"))
local PhobosEvent = require(script:FindFirstChild("phobos_event_server.lua"))
local ViralHub = require(script:FindFirstChild("viral_hub_agent.lua"))
local vault = SatoshiVault:create(script.Parent.Parent.Parent, "SatoshiVaultRemote")
local event = PhobosEvent:initialize(script.Parent.Parent.Parent)
local hub = ViralHub:initialize(script.Parent.Parent.Parent)
print("[AriaVerse] All systems operational!")
]]>
            </Item>
          </Item>
          <Item name="satoshi_vault_server.lua" Class="ModuleScript">
            <Item name="Name" value="satoshi_vault_server.lua"/>
            <Item name="Source">
<![CDATA[
local SatoshiVault = {}
SatoshiVault.__index = SatoshiVault
SatoshiVault.MIN_POOL = 500000
SatoshiVault.MAX_POOL = 2000000
SatoshiVault.BASE_COST = 10000
SatoshiVault.DAILY_SPIN_LIMIT = 10

function SatoshiVault:create(instance, remoteEventName)
    local self = setmetatable({}, SatoshiVault)
    self.pool = SatoshiVault.MIN_POOL
    local vaultRemote = instance:FindFirstChild(remoteEventName)
    if not vaultRemote then
        vaultRemote = Instance.new("RemoteEvent")
        vaultRemote.Name = remoteEventName
        vaultRemote.Parent = instance
    end
    vaultRemote.OnServerEvent:Connect(function(player, action)
        self:HandleVaultEvent(player, tostring(action))
    end)
    return self
end

function SatoshiVault:HandleVaultEvent(player, action)
    if not player or not player.UserId then return end
    if action == "spin" then
        self:ProcessSpin(player)
    elseif action == "getPool" then
        self:ReturnPoolData(player)
    end
end

function SatoshiVault:ProcessSpin(player)
    local totalCost = SatoshiVault.BASE_COST
    local availableBalance = 50000
    if availableBalance >= totalCost then
        player:SaveBalance(player.UserId, player:GetBalance(player.UserId) - totalCost)
        local key = self:GenerateRandomKey()
        local match = self:CountMatches(#key, "ABCDEF")
        local prize = self:CalculatePrize(match)
        self.pool = math.min(self.pool + 25, SatoshiVault.MAX_POOL)
        vaultRemote:FirePlayer(player, "WIN", {prize = prize, pool = self.pool})
    end
end

function SatoshiVault:GenerateRandomKey()
    local key = ""
    local hexChars = "0123456789ABCDEF"
    for i = 1, 6 do
        key = key .. string.sub(hexChars, math.random(1, 16), math.random(1, 16))
    end
    return key
end

function SatoshiVault:CountMatches(keyLen, selection)
    local matchCount = 0
    for i = 1, keyLen do
        if selection:sub(i, i) == key:sub(i, i) then
            matchCount = matchCount + 1
        end
    end
    return matchCount
end

function SatoshiVault:CalculatePrize(match)
    if match >= 6 then return self.pool
    elseif match >= 4 then return math.floor(self.pool * 0.20)
    elseif match >= 2 then return math.floor(self.pool * 0.02)
    else return 0
    end
end

return SatoshiVault
]]>
            </Item>
          </Item>
          <Item name="phobos_event_server.lua" Class="ModuleScript">
            <Item name="Name" value="phobos_event_server.lua"/>
            <Item name="Source">
<![CDATA[
local PhobosEvent = {}
PhobosEvent.__index = PhobosEvent
PhobosEvent.EVENT_TRIGGER_TIME = 150
PhobosEvent.RING_DEBRIS_COUNT = 50

function PhobosEvent:initialize(scriptService)
    self.scriptService = scriptService
    self.eventRemote = scriptService:FindFirstChild("PhobosEventRemote")
    if not self.eventRemote then
        self.eventRemote = Instance.new("RemoteEvent")
        self.eventRemote.Name = "PhobosEventRemote"
        self.eventRemote.Parent = scriptService
    end
    self.isActive = false
    self.eventRemote.OnServerEvent:Connect(function(player, event, data)
        self:HandleEventRequest(player, event, data)
    end)
    return setmetatable({}, self)
end

function PhobosEvent:HandleEventRequest(player, event, data)
    if event == "startEvent" then
        self:StartEvent()
    end
end

function PhobosEvent:StartEvent()
    self.isActive = true
    self.phase = 1
    local lighting = game:GetService("Lighting")
    lighting.TintColor = Color3.fromRGB(255, 60, 60)
    print("[PhobosEvent] Event started")
end

return PhobosEvent
]]>
            </Item>
          </Item>
          <Item name="viral_hub_agent.lua" Class="ModuleScript">
            <Item name="Name" value="viral_hub_agent.lua"/>
            <Item name="Source">
<![CDATA[
local ViralHub = {}
ViralHub.__index = ViralHub
ViralHub.AI_SERVER = "159.65.178.129"
ViralHub.AI_PORT = 11434

function ViralHub:initialize(scriptService)
    self.contentQueue = []
    print("[ViralHub] AI Agent initialized")
    return setmetatable({}, self)
end

return ViralHub
]]>
            </Item>
          </Item>
        </Item>
      </Item>
      <Item name="Workspace" Class="Workspace">
        <Item name="AriaVerseAssets" Class="Folder"/>
      </Item>
      <Item name="Lighting" Class="Lighting"/>
      <Item name="StarterGui" Class="StarterGui"/>
      <Item name="StarterPlayer" Class="StarterPlayer"/>
    </Instances>
  </Game>
</roblox>